# Forge Builder configuration
# Copy to .env and fill in your values

# Required
FORGE_GITHUB_REPO=youruser/forge
FORGE_REPO_DIR=/opt/forge
ANTHROPIC_API_KEY=sk-ant-...

# Budget controls
FORGE_DAILY_BUDGET=5.00          # Max USD per day
FORGE_PER_ISSUE_BUDGET=1.50      # Max USD per issue before downgrading to haiku

# Model strategy: "auto" (recommended) or set FORGE_CLAUDE_MODEL explicitly
FORGE_MODEL_STRATEGY=auto
# FORGE_CLAUDE_MODEL=claude-sonnet-4-6

# Schedule: only build during these UTC hours (empty = always)
# Example: overnight only (10pm-6am UTC)
# FORGE_ACTIVE_HOURS=22-06

# Polling interval in seconds (default: 300 = 5 min)
FORGE_POLL_INTERVAL=300

# Max Claude Code turns per issue (default: 50)
FORGE_CLAUDE_MAX_TURNS=50

# Budget log location
FORGE_BUDGET_LOG=/opt/forge/infra/builder/budget.jsonl
